---
import { contactInfo, siteInfo } from "../consts";
import { LogoPaletteToggle } from "./app/LogoPaletteToggle";
import { NavModal } from "./app/NavModal";
import { NavModalToggle } from "./app/NavModalToggle";
import { PaletteModal } from "./app/PaletteModal";

type NavIcon = {
  url: string;
  alt: string;
  icon: string;
};

type NavLink = {
  url: string;
  name: string;
};

export const navIcons: Array<NavIcon> = [
  {
    icon: "icon-linkedin-square",
    alt: "View my linkedin profile.",
    url: contactInfo.linkedInUrl,
  },
  {
    icon: "icon-github",
    alt: "Check out my github.",
    url: contactInfo.githubUrl,
  },
  {
    icon: "icon-twitter",
    alt: "Check out my sparsely used Twitter account.",
    url: contactInfo.twitterUrl,
  },
];

const navLinks: Array<NavLink> = [
  { url: "/", name: "Home" },
  { url: "/blog", name: "Blog" },
  { url: "/recipes", name: "Recipes" },
  { url: "/about", name: "About" },
];
---

<!-- todo: figure out how to correctly override the bulma vars for this -->
<nav
  class="navbar"
  role="navigation"
  style="--bulma-navbar-burger-color: var(--textColor);"
>
  <div class="navbar-brand">
    <LogoPaletteToggle client:idle />
    <a class="navbar-item logo-text" href="/">{siteInfo.navBrandText}</a>
    <NavModalToggle client:idle />
  </div>
  <div class="navbar-menu">
    <div class="navbar-end">
      {
        navIcons.map(({ alt, icon, url }) => (
          <a class="navbar-item is-hidden-mobile" href={url}>
            <span class={icon} title={alt} />
          </a>
        ))
      }
      {
        navLinks.map(({ url, name }) => (
          <a class="navbar-item is-tab" href={url}>
            {name}
          </a>
        ))
      }
    </div>
  </div>
  <NavModal client:load />
  <PaletteModal client:load />
</nav>
<style is:inline>
  .logo-img {
    display: block;
    width: 3rem;
    height: 3rem;
    transition: 0.2s ease-in-out;

    span {
      svg {
        height: 3rem;
        width: auto;
        max-height: 3rem;
      }
    }
  }

  .logo-img:hover {
    transform: rotate(180deg);
  }
</style>
<style lang="scss">
  @use "bulma/sass/utilities/mixins" as mixins;

  nav {
    background-color: var(--backgroundColor);
    color: var(--titleTextColor);
    align-items: flex-end;
    font-family: var(--displayFonts);
    margin: 0rem auto;
    height: 4rem;
    max-width: var(--pageWidth);
    align-items: center;
  }

  .navbar-brand {
    background-color: var(--backgroundColor);

    align-items: center;

    @include mixins.touch {
      padding: 0.5rem;
    }
  }

  .burger {
    color: var(--textColor);
    height: 4rem;
    width: 4rem;
  }

  .burger-span {
    color: var(--textColor);
  }

  .navbar-menu {
    box-shadow: none;
    background-color: var(--backgroundColor);
  }

  a.navbar-item {
    color: var(--subtitleTextColor);

    &.is-tab {
      font-size: 1.125rem;
      // align visually with 'zmsy.co' text
      min-height: 2.75rem;
    }

    &:hover {
      background-color: var(--backgroundAccentColor);
    }
  }

  .navbar-end {
    @include mixins.desktop {
      align-items: flex-end;
    }
  }

  .navbar-end a:hover,
  .fa:hover {
    background-color: var(--backgroundAccentColor);
    color: var(--subtitleTextColor);
  }

  .logo-text {
    font-size: 2rem;
    justify-content: flex-start;
    font-family: var(--displayFonts);
  }
</style>
