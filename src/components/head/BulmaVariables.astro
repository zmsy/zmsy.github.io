---
/**
 * Palette-driven Bulma CSS variables.
 *
 * Bulma v1 uses CSS variables for theming; we map our existing palette system
 * onto Bulma's `--bulma-*` tokens so Bulma components respond to `data-palette`
 * changes at runtime.
 */

import {
  paletteEntries,
  palettes,
  type Palette,
} from "@src/components/app/palette";
import convert from "color-convert";

type PaletteColors = Palette["colors"];

type Hsl = { h: number; s: number; l: number };

const hexToHsl = (hex: string): Hsl => {
  const [h, s, l] = convert.hex.hsl(hex);
  return { h, s, l };
};

const bulmaVarsForPalette = (colors: PaletteColors, indent: string): string => {
  const bg = hexToHsl(colors.background);
  const text = hexToHsl(colors.text);
  const link = hexToHsl(colors.accent1);
  const primary = link;

  // These are the minimum vars that affect the Bulma modules we use (base,
  // content, navbar, modal, card).
  return [
    `${indent}--bulma-body-background-color: var(--backgroundColor);`,
    `${indent}--bulma-body-color: var(--textColor);`,
    `${indent}--bulma-scheme-h: ${bg.h};`,
    `${indent}--bulma-scheme-s: ${bg.s}%;`,
    `${indent}--bulma-scheme-main: var(--backgroundColor);`,
    `${indent}--bulma-scheme-main-bis: var(--backgroundAccentColor);`,
    `${indent}--bulma-background: var(--backgroundAccentColor);`,
    `${indent}--bulma-border: var(--backgroundAccentColor);`,
    `${indent}--bulma-text-h: ${text.h};`,
    `${indent}--bulma-text-s: ${text.s}%;`,
    `${indent}--bulma-text-l: ${text.l}%;`,
    `${indent}--bulma-text: var(--textColor);`,
    `${indent}--bulma-text-weak: var(--textLowContrastColor);`,
    `${indent}--bulma-text-strong: var(--titleTextColor);`,
    `${indent}--bulma-link-h: ${link.h};`,
    `${indent}--bulma-link-s: ${link.s}%;`,
    `${indent}--bulma-link-l: ${link.l}%;`,
    `${indent}--bulma-link: var(--accent1Color);`,
    `${indent}--bulma-primary-h: ${primary.h};`,
    `${indent}--bulma-primary-s: ${primary.s}%;`,
    `${indent}--bulma-primary-l: ${primary.l}%;`,
    `${indent}--bulma-family-primary: var(--readingFonts);`,
    `${indent}--bulma-family-secondary: var(--subtitleFonts);`,
    `${indent}--bulma-family-code: var(--codeFonts);`,
  ].join("\n");
};

const baseCSS = bulmaVarsForPalette(palettes.defaultLight.colors, "    ");
const darkPrefCSS = bulmaVarsForPalette(palettes.defaultDark.colors, "      ");

const paletteRules = paletteEntries
  .map(([id, palette]) => {
    return [
      `  html[data-palette="${id}"] {`,
      bulmaVarsForPalette(palette.colors, "    "),
      "  }",
    ].join("\n");
  })
  .join("\n\n");

const css = `
  html {
${baseCSS}
  }

  @media (prefers-color-scheme: dark) {
    html:not([data-palette]) {
${darkPrefCSS}
    }
  }

${paletteRules}
`.trim();
---

<style is:global is:inline set:html={css}></style>
